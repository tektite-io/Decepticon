{"id": "DCEP-T1078.002-pass-the-hash", "title": "Pass-the-Hash via psexec/wmiexec/smbexec with -hashes", "level": "high", "mitre": ["T1078.002", "T1550.002"], "selections": {"tool": {"actor.command_line": "re:(?:psexec|wmiexec|smbexec|atexec)\\.py"}, "hash_flag": {"actor.command_line": "-hashes"}}, "condition": "tool and hash_flag"}
